# results journal — untracked by design so experience survives `git reset`
results.tsv
# but DO track frozen snapshots under versions/
!versions/**/results.tsv

# ict-engine lane artifacts stay in /tmp unless frozen as evidence under versions/
/plan.md
/failure_patterns.md
/harness_layer_updates.md
/review.md
/regression_review.md
/strategy_library.json
/adoption_bundle*.json

# Local data/provider config
profile_source.csv
config.*.json
!config.json
!versions/**/config.*.json
scripts/ibkr_bridge/my_config*.yaml
scripts/ibkr_bridge/my_config*.yaml.*

# run logs — every experiment writes run.log, never commit
run.log
*.log
# but DO track frozen run-log snapshots under versions/
!versions/**/run.log
!versions/**/*.log

# FreqTrade-generated output
user_data/strategies/*.py
user_data/strategies/_archive/
!user_data/strategies/_template.py.example
!versions/**/user_data/strategies/**
user_data/data/
user_data/backtest_results/
user_data/logs/
user_data/hyperopt_results/
user_data/notebooks/.ipynb_checkpoints/

# Python / uv
__pycache__/
*.pyc
.venv/
.python-version.lock

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Jupyter
.ipynb_checkpoints/
